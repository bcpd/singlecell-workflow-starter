/*
 * Docker profile notes:
 * - Build the project images from containers/*.Dockerfile before using this profile.
 * - Cell Ranger is not containerized here because its licensing/install requirements differ from OSS tools.
 * - Raw FASTQ-to-count workflows should use nf-core/scrnaseq with its official profiles.
 */

process {
    withName:RUN_SCANPY {
        container = "single-cell-workflows-starter-scanpy:0.1.0"
    }

    withName:RUN_SEURAT {
        container = "single-cell-workflows-starter-seurat:0.1.0"
    }
}
