/*
 * Nextflow configuration for the downstream scRNA-seq production starter.
 */

params {
    // Canonical input table with sample,matrix_dir and optional species,genome,mt_prefix columns.
    samplesheet = null

    // Single-sample compatibility input with matrix.mtx(.gz), barcodes.tsv(.gz), and features.tsv(.gz)/genes.tsv(.gz).
    matrix_dir = null

    // Sample identifier used with --matrix_dir.
    sample = "pbmc_demo"

    // Sample metadata defaults used when not supplied in the samplesheet.
    species = "human"
    genome = ""
    mt_prefix = null

    // Shared QC and clustering defaults.
    min_features = 200
    max_features = 2500
    max_mt = 5.0
    cluster_resolution = 0.5

    // Output directory.
    outdir = "results/local_nextflow"
}

manifest {
    nextflowVersion = ">=26.0.0"
}

process {
    // Retry once for transient process failures.
    errorStrategy = "retry"
    maxRetries = 1

    // Conservative defaults for laptop execution.
    cpus = 4
    memory = "8 GB"
    time = "4h"
}

profiles {
    conda {
        conda.enabled = true
        conda.useMicromamba = true
        conda.cacheDir = "${projectDir}/work/conda"
    }

    docker {
        docker.enabled = true
        includeConfig "conf/docker.config"
    }
}
